{
  "name": "hnefatafl-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:visual": "playwright test e2e/visual.test.ts",
    "test:visual:update": "playwright test e2e/visual.test.ts --update-snapshots",
    "generate:types": "openapi-typescript ../backend/openapi.json -o src/api/generated/rest.ts"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.11",
    "@solidjs/router": "^0.16.1",
    "openapi-fetch": "^0.17.0",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@playwright/test": "^1.58.2",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^29.0.1",
    "openapi-typescript": "^7.6.1",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^4.1.0"
  }
}
